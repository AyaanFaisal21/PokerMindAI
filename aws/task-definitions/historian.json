{
  "family": "pokermind-historian",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::ACCOUNT_ID:role/pokermind-ecs-execution-role",
  "taskRoleArn": "arn:aws:iam::ACCOUNT_ID:role/pokermind-ecs-task-role",
  "containerDefinitions": [
    {
      "name": "historian",
      "image": "ACCOUNT_ID.dkr.ecr.us-east-1.amazonaws.com/pokermind-historian:latest",
      "portMappings": [
        { "containerPort": 8002, "protocol": "tcp" }
      ],
      "environment": [
        { "name": "LLM_MODEL", "value": "claude-haiku-4-5-20251001" },
        { "name": "REDIS_URL", "value": "redis://pokermind-redis.internal:6379" }
      ],
      "secrets": [
        {
          "name": "ANTHROPIC_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:ACCOUNT_ID:secret:pokermind/anthropic-api-key"
        }
      ],
      "healthCheck": {
        "command": ["CMD-SHELL", "curl -f http://localhost:8002/health || exit 1"],
        "interval": 15,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 30
      },
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/pokermind/historian",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
