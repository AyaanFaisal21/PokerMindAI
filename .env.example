# Required
ANTHROPIC_API_KEY=sk-ant-...

# Optional — defaults shown
LLM_MODEL=claude-haiku-4-5-20251001
REDIS_URL=redis://localhost:6379

# Service URLs (used by orchestrator, override for cloud)
STRATEGIST_URL=http://strategist:8001
HISTORIAN_URL=http://historian:8002
HUMANIZER_URL=http://humanizer:8003

# AWS deployment (only needed for deploy.sh)
AWS_ACCOUNT_ID=
AWS_REGION=us-east-1
